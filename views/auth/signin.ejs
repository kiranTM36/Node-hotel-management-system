<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Document</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Kedebideri:wght@400;500;600;700;800;900&family=Oswald:wght@200..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&family=Wix+Madefor+Text:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('./../component/header.ejs', {hotel : hotel}) %>

    <div class="main">
    <div class="left">
        <div class="form-overlay"></div>
        <div class="text">
            <h1>Welcome to <h1 class="hName">NP Royal Hotel</h1></h1>
            <p>Sign in to enjoy exclusive services and offers.</p>
        </div>
    </div>

    <form action="/customer/signin" method="post" class="right">
        <h2>Sign In</h2>

        <div class="label">
            <label>Username</label>
            <input type="text" name="name" placeholder="Enter your username" required>
        </div>

        <div class="label">
            <label>Phone No</label>
            <input type="text" name="phone" placeholder="Enter your phone number" required>
        </div>

        <div class="label">
            <label>Email</label>
            <input type="email" name="email" placeholder="Enter your email" required>
        </div>

        <div class="label">
            <label>Password</label>
            <input type="password" name="password" placeholder="Enter your password" required>
        </div>

        <input type="submit" value="Sign In">
        <p class="signup-text">Already have an account? <a href="login">LogIn</a></p>
    </form>
</div>
</body>
</html>